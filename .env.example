# Trinamix Conversion Workbench — Environment Configuration
# Copy this file to .env and adjust as needed

# Database
DATABASE_URL=sqlite:///./conversion_workbench.db

# File storage paths (relative to backend/ or absolute)
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# Auth
JWT_SECRET=trinamix-local-dev-secret-change-me
JWT_EXPIRE_MINUTES=480

# Seed admin
ADMIN_EMAIL=admin@trinamix.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Trinamix Admin

# AI Provider — one of: none | anthropic | openai
# When set to "none", deterministic rule-based mapping is used (works fully offline).
AI_PROVIDER=none
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CORS — frontend origin
FRONTEND_ORIGIN=http://localhost:5173
